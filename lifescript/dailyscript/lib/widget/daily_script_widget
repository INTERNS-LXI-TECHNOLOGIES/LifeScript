import 'package:flutter/material.dart';

class RoleDragApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      home: RoleDragPage(),
    );
  }
}

class RoleDragPage extends StatefulWidget {
  @override
  _RoleDragPageState createState() => _RoleDragPageState();
}

class _RoleDragPageState extends State<RoleDragPage> {
  String? droppedRole;
  bool isRoleDropped = false;

  // Default schedule for 24 hours
  List<String> schedule = [];

  @override
  void initState() {
    super.initState();
    resetSchedule();
  }

  void resetSchedule() {
    setState(() {
      schedule = [
        ...List.filled(8 * 6, 'Sleep'), // 8 hours of sleep (48 blocks)
        ...List.generate(16 * 6, (index) => (index % 6 < 4) ? 'Work' : 'Break'), // Pomodoro (16 hours)
      ];
    });
  }

  @override
  Widget build(BuildContext context) {
    return Scaffold(
      appBar: AppBar(
        title: Text(
          'Drag Your Role',
          style: TextStyle(color: Colors.white),
        ),
        backgroundColor: Colors.black,
        actions: [
          IconButton(
            icon: Icon(Icons.refresh),
            onPressed: resetSchedule,
          ),
        ],
      ),
      body: Stack(
        children: [
          // Background Gradient
          Container(
            decoration: BoxDecoration(
              gradient: LinearGradient(
                colors: [Colors.black, Colors.white],
                begin: Alignment.topLeft,
                end: Alignment.bottomRight,
              ),
            ),
          ),

          // Main content
          Center(
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                if (!isRoleDropped)
                  DragTarget<String>(
                    onAccept: (data) {
                      setState(() {
                        droppedRole = data;
                        isRoleDropped = true;
                      });
                    },
                    builder: (context, candidateData, rejectedData) {
                      return Container(
                        width: 150,
                        height: 150,
                        alignment: Alignment.center,
                        decoration: BoxDecoration(
                          color: Colors.white.withOpacity(0.2),
                          borderRadius: BorderRadius.circular(10),
                          border: Border.all(color: Colors.white, width: 2),
                        ),
                        child: Text(
                          isRoleDropped ? droppedRole ?? 'Dropped!' : 'Drop Here',
                          style: TextStyle(
                            color: Colors.white,
                            fontSize: 14,
                            fontWeight: FontWeight.bold,
                          ),
                          textAlign: TextAlign.center,
                        ),
                      );
                    },
                  ),
                SizedBox(height: 20),

                // Draggable Roles
                if (!isRoleDropped)
                  Wrap(
                    spacing: 15,
                    children: [
                      _buildDraggableRole('Student', Colors.blue),
                      _buildDraggableRole('Developer', Colors.green),
                      _buildDraggableRole('Designer', Colors.orange),
                      _buildDraggableRole('Manager', Colors.red),
                    ],
                  ),
                SizedBox(height: 20),

                // Grid View
                if (isRoleDropped)
                  Expanded(
                    child: Padding(
                      padding: const EdgeInsets.symmetric(horizontal: 8.0),
                      child: Column(
                        children: [
                          Text(
                            'Customize 24-Hour Plan for $droppedRole',
                            style: TextStyle(
                              color: Colors.white,
                              fontSize: 14,
                              fontWeight: FontWeight.bold,
                            ),
                          ),
                          SizedBox(height: 10),
                          Expanded(
                            child: GridView.builder(
                              gridDelegate: SliverGridDelegateWithFixedCrossAxisCount(
                                crossAxisCount: 24, // 24 grids in a row
                                mainAxisSpacing: 2,
                                crossAxisSpacing: 2,
                              ),
                              itemCount: 96, // 96 blocks for 24 hours (4 rows x 24 columns)
                              itemBuilder: (context, index) {
                                return DragTarget<int>(
                                  onWillAccept: (data) => data != null,
                                  onAccept: (sourceIndex) {
                                    setState(() {
                                      // Swap the source and target items
                                      final temp = schedule[sourceIndex];
                                      schedule[sourceIndex] = schedule[index];
                                      schedule[index] = temp;
                                    });
                                  },
                                  builder: (context, candidateData, rejectedData) {
                                    return Draggable<int>(
                                      data: index,
                                      feedback: _buildGridItem(schedule[index], _getColor(schedule[index]), isDragging: true),
                                      childWhenDragging: _buildGridItem(schedule[index], _getColor(schedule[index]).withOpacity(0.5)),
                                      child: _buildGridItem(schedule[index], _getColor(schedule[index])),
                                    );
                                  },
                                );
                              },
                            ),
                          ),
                        ],
                      ),
                    ),
                  ),
              ],
            ),
          ),
        ],
      ),
    );
  }

  Widget _buildDraggableRole(String role, Color color) {
    return Draggable<String>(
      data: role,
      feedback: _buildRoleChip(role, color, isDragging: true),
      childWhenDragging: _buildRoleChip(role, color.withOpacity(0.5), isDragging: false),
      child: _buildRoleChip(role, color, isDragging: false),
    );
  }

  Widget _buildRoleChip(String role, Color color, {required bool isDragging}) {
    return Material(
      color: Colors.transparent,
      child: Container(
        padding: EdgeInsets.symmetric(horizontal: 15, vertical: 8),
        decoration: BoxDecoration(
          color: color,
          borderRadius: BorderRadius.circular(20),
          boxShadow: isDragging
              ? [
                  BoxShadow(
                    color: color.withOpacity(0.6),
                    blurRadius: 10,
                    spreadRadius: 2,
                  ),
                ]
              : [],
        ),
        child: Text(
          role,
          style: TextStyle(
            color: Colors.white,
            fontSize: 14,
            fontWeight: FontWeight.bold,
          ),
        ),
      ),
    );
  }

  Widget _buildGridItem(String text, Color color, {bool isDragging = false}) {
    return Container(
      decoration: BoxDecoration(
        color: color,
        borderRadius: BorderRadius.circular(3),
        border: isDragging ? Border.all(color: Colors.white, width: 2) : null,
      ),
      alignment: Alignment.center,
      child: Text(
        text,
        style: TextStyle(
          color: Colors.white,
          fontSize: 10,
          fontWeight: FontWeight.bold,
        ),
      ),
    );
  }

  Color _getColor(String text) {
    switch (text) {
      case 'Sleep':
        return Colors.purple;
      case 'Work':
        return Colors.green;
      case 'Break':
        return Colors.blue;
      default:
        return Colors.grey;
    }
  }
}
